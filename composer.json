{
    "name": "appnave/nave-cadastros-sp",
    "description": "Pacote Laravel para sincronização e importação de dados do SP via RabbitMQ.",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "BildVitta\\SpProduto\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "BildVitta\\SpProduto\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.1|^8.2|^8.3",
        "appnave/nave-sdk-iss": "^0.2",
        "illuminate/contracts": "^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
        "php-amqplib/php-amqplib": "^3.2.0",
        "ramsey/uuid": "^4.2.2",
        "spatie/laravel-package-tools": "^1.12"
    },
    "require-dev": {
        "brianium/paratest": "^6.6",
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^6.2",
        "orchestra/testbench": "^7.6",
        "phpunit/phpunit": "^9.5|^12.0"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/appnave/nave-sdk-iss.git"
        }
    ],
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "BildVitta\\SpProduto\\SpProdutoServiceProvider"
            ],
            "aliases": {
                "MessagesCrm": "BildVitta\\SpProduto\\SpProdutoFacade"
            }
        }
    },
    "prefer-stable": true,
    "minimum-stability": "dev",
    "scripts": {
        "test": "./vendor/bin/testbench package:test --parallel --no-coverage",
        "test-coverage": "php -d xdebug.mode=coverage vendor/bin/phpunit --coverage-html coverage",
        "check-style": [
            "vendor/bin/pint --test"
        ],
        "fix-style": [
            "vendor/bin/pint"
        ]
    }
}